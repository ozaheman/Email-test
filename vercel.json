{
  "version": 2,
  "functions": {
    "api/send.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30,
      "memory": 256
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}